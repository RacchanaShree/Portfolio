<!DOCTYPE html>

<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Rachana S Reddy | Java Full Stack Developer</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600&amp;family=JetBrains+Mono:wght@400;500&amp;family=Orbitron:wght@900&amp;family=Righteous&amp;family=Rajdhani:wght@700&amp;family=Audiowide&amp;display=swap" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
    <!-- AOS Animation Library CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script id="tailwind-config">
          tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                colors: {
                  "tertiary-container": "#9900b1",
                  "on-primary-container": "#e4c4ff",
                  "on-tertiary": "#570066",
                  "on-background": "#e3e0f4",
                  "primary-fixed": "#f0dbff",
                  "inverse-surface": "#e3e0f4",
                  "on-secondary-container": "#005441",
                  "tertiary": "#faabff",
                  "primary": "#deb7ff",
                  "primary-container": "#7b2fbe",
                  "surface": "var(--surface)",
                  "on-secondary-fixed": "#002118",
                  "surface-bright": "var(--surface-bright)",
                  "on-primary": "#4a007f",
                  "on-tertiary-fixed": "#35003f",
                  "secondary": "#41eec2",
                  "on-secondary": "#00382b",
                  "primary-fixed-dim": "#deb7ff",
                  "on-tertiary-container": "#fcbaff",
                  "on-surface-variant": "var(--on-surface-variant)",
                  "surface-tint": "#deb7ff",
                  "tertiary-fixed": "#ffd6fe",
                  "secondary-fixed": "#55fcd0",
                  "surface-container": "var(--surface-container)",
                  "surface-container-low": "var(--surface-container-low)",
                  "surface-container-highest": "var(--surface-container-highest)",
                  "outline": "var(--outline)",
                  "on-error-container": "#ffdad6",
                  "on-surface": "var(--on-surface)",
                  "outline-variant": "var(--outline-variant)",
                  "error": "#ffb4ab",
                  "on-error": "#690005",
                  "inverse-on-surface": "#2f2f3d",
                  "on-tertiary-fixed-variant": "#7b008f",
                  "background": "var(--background)",
                  "surface-variant": "var(--surface-variant)",
                  "secondary-fixed-dim": "#28dfb5",
                  "tertiary-fixed-dim": "#faabff",
                  "surface-container-high": "var(--surface-container-high)",
                  "surface-container-lowest": "var(--surface-container-lowest)",
                  "on-primary-fixed-variant": "#6712aa",
                  "on-secondary-fixed-variant": "#00513f",
                  "inverse-primary": "#8136c4",
                  "error-container": "#93000a",
                  "on-primary-fixed": "#2c0050",
                  "secondary-container": "#00d1a7",
                  "surface-dim": "#12121f"
                },
                fontFamily: {
                  "headline": ["Space Grotesk"],
                  "body": ["Inter"],
                  "label": ["JetBrains Mono"]
                },
                borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
              },
            },
          }
    </script>
    <script src="https://www.google.com/recaptcha/api.js?render=6LdVDqlsAAAAAD5CtA0V5S4euem_aPbsu0ST6SiH"></script>
    <style>
          :root {
            --bg-color: #f8f6fb;
            --text-primary: #1c1b1f;
            --text-secondary: #49454f;
            --text-inverse: #ffffff;
            --surface-color: rgba(255, 255, 255, 0.7);
            --outline-color: rgba(0, 0, 0, 0.1);
            --dot-color: rgba(0, 0, 0, 0.05);
            --navbar-bg: rgba(255, 255, 255, 0.85);
            --card-shadow: 0 8px 32px 0 rgba(123, 47, 190, 0.05);
            
            /* Light Theme Tailwind Mappings */
            --surface: #ffffff;
            --surface-bright: #f0ecf4;
            --surface-container-lowest: #ffffff;
            --surface-container-low: #f4eff8;
            --surface-container: #ede8f2;
            --surface-container-high: #e6e0eb;
            --surface-container-highest: #dfdae4;
            --outline: #9a94a0;
            --outline-variant: #cec7d4;
            --on-surface: #1c1b1f;
            --on-surface-variant: #49454f;
            --background: #f8f6fb;
            --surface-variant: #e6e0eb;
          }

          .dark {
            --bg-color: #0d0d1a;
            --text-primary: #e3e0f4;
            --text-secondary: #cfc2d5;
            --text-inverse: #1c1b1f;
            --surface-color: rgba(26, 26, 46, 0.6);
            --outline-color: rgba(152, 141, 158, 0.1);
            --dot-color: #2a2a45;
            --navbar-bg: rgba(26, 26, 46, 0.6);
            --card-shadow: 0 8px 32px 0 rgba(123, 47, 190, 0.1);
            
            /* Dark Theme Tailwind Mappings (Original Hexes) */
            --surface: #12121f;
            --surface-bright: #383847;
            --surface-container-lowest: #0d0d1a;
            --surface-container-low: #1a1a28;
            --surface-container: #1e1e2c;
            --surface-container-high: #292937;
            --surface-container-highest: #343342;
            --outline: #988d9e;
            --outline-variant: #4c4353;
            --on-surface: #e3e0f4;
            --on-surface-variant: #cfc2d5;
            --background: #12121f;
            --surface-variant: #343342;
          }

          html {
            scroll-behavior: smooth;
            scroll-padding-top: 5rem;
            overflow-x: hidden;
          }
          body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            transition: background-color 0.5s ease, color 0.5s ease;
          }
          .aurora-bg {
            background: radial-gradient(circle at 20% 30%, rgba(123, 47, 190, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 80% 70%, rgba(0, 212, 170, 0.1) 0%, transparent 50%);
          }
          .glass-card {
            background: var(--surface-color);
            backdrop-filter: blur(16px);
            border: 1px solid var(--outline-color);
            box-shadow: var(--card-shadow);
          }
          .dot-grid {
            background-image: radial-gradient(var(--dot-color) 1px, transparent 1px);
            background-size: 32px 32px;
          }
          /* Font Awesome sizing consistency */
          .fa-icon { font-size: 1.25rem; }

          ::-webkit-scrollbar { width: 8px; }
          ::-webkit-scrollbar-track { background: var(--bg-color); }
          ::-webkit-scrollbar-thumb { background: #7b2fbe; border-radius: 4px; }
          .text-glow { text-shadow: 0 0 15px rgba(222, 183, 255, 0.4); }
          .border-glow:hover { box-shadow: 0 0 20px rgba(123, 47, 190, 0.3); border-color: #7b2fbe; }
          
          @keyframes float {
            0%, 100% { transform: translateY(0) rotate(2deg); }
            50% { transform: translateY(-20px) rotate(0deg); }
          }
          .animate-float { animation: float 6s ease-in-out infinite; }
          
          /* Section Text Adjustments */
          .text-on-surface-variant { color: var(--text-secondary); }
          .admin-tab-btn { color: var(--text-secondary); }
          
          #back-to-top {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 99;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
          }
          #back-to-top.visible {
            opacity: 1;
            visibility: visible;
          }
        /* CMS Sidebar Tabs */
    .admin-tab-btn { font-size: 0.9rem; font-family: 'Inter', sans-serif; }
    .admin-tab-btn.active { background: rgba(0, 212, 170, 0.1); color: #00D4AA; font-weight: 700; border-right: 3px solid #00D4AA; }
    .admin-panel { animation: fadeIn 0.4s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Dark mode specific text overrides for headers */
    .dark h1, .dark h2, .dark h3, .dark h4, .dark h5 { color: white; }
    h1, h2, h3, h4, h5 { transition: color 0.5s ease; color: var(--text-primary); }

    /* Professional 3D Logo Styling (Inspired by Example) */
    .logo-container { perspective: 1000px; transform-style: preserve-3d; }
    .logo-rsr-box {
        position: relative;
        padding: 6px 16px;
        background: rgba(0, 0, 0, 0.4);
        border: 2px solid transparent;
        background-image: linear-gradient(rgba(13, 13, 26, 0.8), rgba(13, 13, 26, 0.8)), 
                          linear-gradient(135deg, #41eec2, #7b2fbe);
        background-origin: border-box;
        background-clip: border-box;
        -webkit-background-clip: padding-box, border-box; /* Necessary for browsers */
        border-radius: 8px;
        transform: skewX(-12deg);
        box-shadow: 0 0 15px rgba(0, 212, 170, 0.1);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .logo-rsr-text {
        font-family: 'Audiowide', cursive;
        font-weight: 400;
        text-transform: uppercase;
        font-size: 1.4rem;
        letter-spacing: 0.05em;
        background: linear-gradient(to right, #41eec2, #deb7ff);
        -webkit-background-clip: text;
        background-clip: text; /* Standard support */
        -webkit-text-fill-color: transparent;
        transform: skewX(12deg); 
        display: block;
        transition: all 0.5s ease;
        filter: drop-shadow(0 0 10px rgba(65, 238, 194, 0.4));
    }
    .logo-container:hover .logo-rsr-box {
        transform: skewX(-12deg) rotateX(10deg) rotateY(-15deg) translateZ(20px) scale(1.05);
        box-shadow: 0 0 30px rgba(123, 47, 190, 0.4), inset 0 0 15px rgba(65, 238, 194, 0.2);
        border-color: rgba(255, 255, 255, 0.2);
    }
    .logo-container:hover .logo-rsr-text {
        filter: drop-shadow(0 0 12px rgba(65, 238, 194, 0.6));
        letter-spacing: 0.05em;
    }
    .logo-rsr-box::after {
        content: '';
        position: absolute;
        inset: -2px;
        background: linear-gradient(135deg, #41eec2, #7b2fbe);
        border-radius: 8px;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.5s ease;
        filter: blur(8px);
    }
    .logo-container:hover .logo-rsr-box::after {
        opacity: 0.6;
    }

    /* Cinematic Splash Screen Styling */
    #splash-screen {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #0d0d1a;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: clip-path 0.8s cubic-bezier(0.77, 0, 0.175, 1), opacity 0.8s ease;
    }
    #splash-screen.fade-out {
        clip-path: circle(0% at 50% 50%);
        opacity: 0;
    }
    .splash-nebula {
        position: absolute;
        inset: 0;
        background: 
            radial-gradient(circle at 20% 30%, rgba(65, 238, 194, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(123, 47, 190, 0.15) 0%, transparent 50%);
        filter: blur(80px);
        animation: nebula-drift 10s infinite alternate ease-in-out;
        z-index: -1;
    }
    @keyframes nebula-drift {
        0% { transform: scale(1) translate(0, 0); }
        100% { transform: scale(1.2) translate(5%, 5%); }
    }
    .splash-logo-container {
        position: relative;
        transform: scale(0.8);
        opacity: 0;
        filter: blur(15px);
        animation: splash-entrance 1s cubic-bezier(0.23, 1, 0.32, 1) forwards 0.2s;
    }
    @keyframes splash-entrance {
        0% { transform: scale(0.8); opacity: 0; filter: blur(15px); }
        100% { transform: scale(1); opacity: 1; filter: blur(0); }
    }
    .splash-logo-container .logo-rsr-text {
        font-size: 3rem;
        letter-spacing: 0.2em;
        position: relative;
        overflow: hidden;
    }
    /* Logo Shimmer Effect */
    .splash-logo-container .logo-rsr-text::after {
        content: '';
        position: absolute;
        top: 0;
        left: -150%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        animation: logo-shimmer 2s infinite ease-in-out;
    }
    @keyframes logo-shimmer {
        0% { left: -150%; }
        100% { left: 150%; }
    }
    .splash-logo-container .logo-rsr-box {
        padding: 16px 32px;
        border-width: 3px;
        box-shadow: 0 0 50px rgba(0, 212, 170, 0.2);
    }
    .splash-particle {
        position: absolute;
        width: 4px;
        height: 4px;
        background: #41eec2;
        border-radius: 50%;
        opacity: 0.4;
        filter: blur(1px);
        animation: particle-float 4s infinite linear;
    }
    @keyframes particle-float {
        0% { transform: translateY(0) translateX(0); opacity: 0; }
        50% { opacity: 0.6; }
        100% { transform: translateY(-100vh) translateX(20px); opacity: 0; }
    }
    body.loading {
        overflow: hidden;
    }

    /* Premium Nav Link Hover Effect */
    .nav-link {
        position: relative;
        transition: color 0.3s ease;
    }
    .nav-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -4px;
        left: 50%;
        background: #00D4AA;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-50%);
        border-radius: 2px;
        box-shadow: 0 0 8px rgba(0, 212, 170, 0.5);
    }
    .nav-link:hover::after {
        width: 80%;
    }
    .nav-link:hover {
        color: #00D4AA !important;
    }
</style>
</head>
<body class="dot-grid loading">

<!-- Splash Screen Intro -->
<div id="splash-screen">
    <div class="splash-nebula"></div>
    <!-- Decorative Particles -->
    <div class="splash-particle" style="top: 20%; left: 15%; animation-delay: 0s;"></div>
    <div class="splash-particle" style="top: 40%; left: 85%; animation-delay: 1.5s;"></div>
    <div class="splash-particle" style="top: 70%; left: 25%; animation-delay: 0.7s;"></div>
    <div class="splash-particle" style="top: 80%; left: 75%; animation-delay: 2.2s;"></div>
    <div class="splash-particle" style="top: 10%; left: 55%; animation-delay: 1.2s;"></div>
    
    <div class="splash-logo-container">
        <div class="logo-rsr-box">
            <span class="logo-rsr-text">RSR</span>
        </div>
    </div>
</div>

<!-- Navbar -->
<nav data-aos="fade-down" data-aos-duration="1000" class="sticky top-0 z-50 w-full bg-[var(--navbar-bg)] backdrop-blur-lg shadow-[var(--card-shadow)] transition-all duration-500">
    <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
        <div class="logo-container">
            <div class="logo-rsr-box">
                <span class="logo-rsr-text">RSR</span>
            </div>
        </div>
        <div class="hidden md:flex items-center gap-8">
            <a class="nav-link font-['Space_Grotesk'] text-sm tracking-tight text-[var(--text-secondary)] transition-colors" href="#about">About</a>
            <a class="nav-link font-['Space_Grotesk'] text-sm tracking-tight text-[var(--text-secondary)] transition-colors" href="#skills">Skills</a>
            <a class="nav-link font-['Space_Grotesk'] text-sm tracking-tight text-[var(--text-secondary)] transition-colors" href="#projects">Projects</a>
            <a class="nav-link font-['Space_Grotesk'] text-sm tracking-tight text-[var(--text-secondary)] transition-colors" href="#experience">Experience</a>
            <a class="nav-link font-['Space_Grotesk'] text-sm tracking-tight text-[var(--text-secondary)] transition-colors" href="#contact">Contact</a>
        </div>
        <div class="flex items-center gap-4">
            <button id="theme-toggle" class="fa-solid fa-moon text-primary scale-110 active:scale-90 transition-all hover:rotate-12 duration-300 p-2 rounded-lg hover:bg-primary/10"></button>
            <button class="md:hidden fa-solid fa-bars text-primary"></button>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center pt-20 aurora-bg px-6 lg:px-24 overflow-hidden">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
            <span data-aos="fade-right" data-aos-delay="100" class="font-label text-secondary tracking-widest text-sm uppercase block">Hello, World! 👋</span>
            <h1 data-aos="fade-right" data-aos-delay="300" class="text-6xl md:text-8xl font-headline font-bold tracking-tighter leading-none dark:text-white">
                Rachana S<br/><span class="text-primary">Reddy</span>
            </h1>
            <div data-aos="fade-right" data-aos-delay="500" class="space-y-4">
                <p class="text-2xl font-label text-secondary/80 h-8">Full Stack Developer</p>
                <p class="text-on-surface-variant max-w-lg text-lg leading-relaxed">
                    Building robust, scalable applications from database to UI, focusing on Spring Boot architecture and modern web ecosystems.
                </p>
            </div>
            <div data-aos="fade-up" data-aos-delay="700" class="flex flex-wrap gap-4 pt-4">
                <a href="#projects" class="px-8 py-4 bg-primary-container text-white font-medium rounded-lg hover:shadow-[0_0_25px_rgba(123,47,190,0.5)] transition-all transform hover:-translate-y-1 flex items-center justify-center">
                    View Projects
                </a>
                <a href="#contact" class="px-8 py-4 border-2 border-secondary text-secondary font-medium rounded-lg hover:bg-secondary/10 transition-all transform hover:-translate-y-1 flex items-center justify-center">
                    Contact Me
                </a>
            </div>
            <div id="hero-social-links" data-aos="fade-in" data-aos-delay="1000" class="flex gap-6 pt-6">
                <a class="text-on-surface-variant hover:text-secondary transition-colors hover:scale-110 transform duration-300" href="https://www.github.com/RacchanaShree" target="_blank" title="GitHub">
                    <i class="fa-brands fa-github"></i>
                </a>
                <a class="text-on-surface-variant hover:text-secondary transition-colors hover:scale-110 transform duration-300" href="https://www.linkedin.com/in/racahanasreddy" target="_blank" title="LinkedIn">
                    <i class="fa-brands fa-linkedin"></i>
                </a>
                <a class="text-on-surface-variant hover:text-secondary transition-colors hover:scale-110 transform duration-300" href="https://www.instagram.com/ph0enix_1411" target="_blank" title="Instagram">
                    <i class="fa-brands fa-instagram"></i>
                </a>
                <a class="text-on-surface-variant hover:text-secondary transition-colors hover:scale-110 transform duration-300" href="mailto:racchanashree@gmail.com" target="_blank" title="Email">
                    <i class="fa-solid fa-envelope"></i>
                </a>
            </div>
        </div>
        <div class="hidden lg:block relative" data-aos="zoom-in-left" data-aos-duration="1500">
            <div class="relative group">
                <!-- Decorative Glow -->
                <div class="absolute -inset-4 bg-gradient-to-r from-primary to-secondary rounded-3xl blur-2xl opacity-20 group-hover:opacity-40 transition-opacity duration-1000 animate-pulse"></div>
                
                <!-- Image Container -->
                <div class="relative glass-card p-4 rounded-3xl border-glow rotate-2 hover:rotate-0 transition-transform duration-700 hover:shadow-[0_0_50px_rgba(123,47,190,0.4)] overflow-hidden animate-float">
                    <img src="Rachu_proff.jpeg" alt="Rachana S Reddy" class="w-full h-[550px] object-cover rounded-2xl grayscale-[10%] hover:grayscale-0 transition-all duration-700 hover:scale-105">
                    
                    <!-- Floating Label -->
                    <div class="absolute bottom-10 left-10 right-10 glass-card p-4 rounded-xl border border-white/10 backdrop-blur-md transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-secondary animate-ping"></div>
                            <span class="text-white font-medium tracking-wide">Available for Projects</span>
                        </div>
                    </div>
                </div>
                
                <!-- Decorative Elements -->
                <div class="absolute -top-6 -right-6 w-24 h-24 bg-primary/20 rounded-full blur-2xl animate-pulse"></div>
                <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-secondary/10 rounded-full blur-3xl animate-pulse"></div>
            </div>
        </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce" data-aos="fade-in" data-aos-delay="1500">
        <i class="fa-solid fa-angles-down text-secondary text-3xl"></i>
    </div>
</section>

<!-- About Section -->
<section class="py-32 px-6 lg:px-24 overflow-hidden" id="about">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="relative flex justify-center" data-aos="fade-right" data-aos-duration="1200">
                <div class="w-72 h-80 relative group">
                    <div class="absolute inset-0 bg-primary-container/20 rounded-full blur-3xl transition-all duration-700 group-hover:bg-primary-container/40 group-hover:blur-2xl"></div>
                    <div class="relative w-full h-full overflow-hidden border-2 border-primary-container p-1 rounded-3xl transform transition-transform duration-700 group-hover:scale-105 shadow-xl">
                        <img alt="Rachana S Reddy" class="w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-700" src="Rachu_selfie.jpeg"/>
                    </div>
                </div>
            </div>
            <div class="space-y-8">
                <div data-aos="fade-left" data-aos-duration="1000">
                    <h2 class="text-4xl font-headline font-bold mb-2 dark:text-white">About Me</h2>
                    <div class="w-20 h-1 bg-secondary rounded-full"></div>
                </div>
                <p data-aos="fade-up" data-aos-delay="200" class="text-on-surface-variant text-lg leading-relaxed">
                    I'm a passionate Full Stack Developer with a strong foundation in backend engineering using Spring Boot and REST APIs. I love building clean, efficient, and scalable web applications that solve real-world problems.
                </p>
                <p data-aos="fade-up" data-aos-delay="400" class="text-on-surface-variant text-lg leading-relaxed">
                    Actively seeking freelance projects and full-stack job offers. I am ready to contribute to high-performance engineering teams and bring modern digital solutions to life.
                </p>
                <div data-aos="zoom-in" data-aos-delay="600" class="flex flex-wrap gap-3">
                    <span class="glass-card px-4 py-2 rounded-full font-label text-sm text-primary border-primary-container/30 hover:bg-primary hover:text-white transition-colors cursor-default">Java</span>
                    <span class="glass-card px-4 py-2 rounded-full font-label text-sm text-primary border-primary-container/30 hover:bg-primary hover:text-white transition-colors cursor-default">Spring Boot</span>
                    <span class="glass-card px-4 py-2 rounded-full font-label text-sm text-primary border-primary-container/30 hover:bg-primary hover:text-white transition-colors cursor-default">REST APIs</span>
